            "sampleData": {},
            "sourceCode": {
              "code": "export const code = async (inputs) => {\n  const payload = inputs.webhookBody;\n  \n  const text = payload?.body || '';\n  const sender = payload?.from || '';\n  const hasMedia = payload?.hasMedia || false;\n  const isGroup = sender.includes('@g.us');\n  const isStatus = sender === 'status@broadcast';\n  const isEmpty = !text || text.trim() === '';\n  const isApiMessage = payload?.source === 'api';\n\n  if (isApiMessage) return { ignore: true, reason: 'botMessage' };\n  if (isStatus || isGroup) return { ignore: true, reason: 'invalid' };\n  if (isEmpty && !hasMedia) return { ignore: true, reason: 'invalid' };\n\n  const isBotMessage =\n    text.startsWith('👋') ||\n    text.startsWith('✅') ||\n    text.startsWith('📋') ||\n    text.startsWith('⏳') ||\n    text.startsWith('❌') ||\n    text.startsWith('📧');\n\n  if (isBotMessage) return { ignore: true, reason: 'botMessage' };\n\n  const lower = text.toLowerCase().trim();\n  let step = 'freetext';\n  let value = text.trim();\n\n  const isHello = ['hello', 'hi', 'helo', 'hii', 'hey', 'start', 'hlo'].includes(lower);\n\n  if (isHello) {\n    step = 'hello';\n  } else if (lower.startsWith('to:')) {\n    step = 'recipient';\n    value = text.replace(/^to:\\s*/i, '').trim();\n  } else if (lower.startsWith('body:') || lower.startsWith('message:')) {\n    step = 'body';\n    value = text.replace(/^(body|message):\\s*/i, '').trim();\n  } else if (lower === 'skip') {\n    step = 'skip_attachment';\n  } else if (lower === 'yes') {\n    step = 'confirm_yes';\n  } else if (lower === 'no') {\n    step = 'confirm_no';\n  } else if (hasMedia) {\n    step = 'media';\n    value = payload?.media?.url || payload?.id || 'media_received';\n  }\n\n  return {\n    step,\n    value,\n    sender,\n    rawText: text,\n    ignore: false,\n    hasMedia\n  };\n};",
