                                  "code": "export const code = async (inputs) => {\n  const response = await fetch('https://api.groq.com/openai/v1/chat/completions', {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n      'Authorization': `Bearer ${inputs.apiKey}`\n    },\n    body: JSON.stringify({\n      model: 'llama-3.3-70b-versatile',\n      messages: [{\n        role: 'user',\n       content: `Convert this informal message into a professional formal email. The sender's name is Anubhav Kumar Srivastava. Return ONLY a raw JSON object with exactly two keys: \"subject\" and \"body\". The body must have proper email structure with line breaks using \\\\n. Format exactly like this:\n\nDear [Name/Sir/Madam],\n\n[Opening line]\n\n[Main content]\n\n[Closing line]\n\nYours sincerely,\nAnubhav Kumar Srivastava\n\nNo markdown, no backticks, no extra text.\n\nInformal message:\n${inputs.emailBody}`\n      }],\n      temperature: 0.7\n    })\n  });\n\n  const data = await response.json();\n  const text = data.choices[0].message.content;\n  const cleaned = text.replace(/```json|```/g, '').trim();\n  const parsed = JSON.parse(cleaned);\n  \n  return {\n    subject: parsed.subject,\n    emailBody: parsed.body.replace(/\\n/g, '<br>')\n  };\n};",
