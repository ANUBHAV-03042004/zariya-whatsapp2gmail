                                  "sourceCode": {
                                    "code": "export const code = async (inputs) => {\n  if (!inputs.attachmentUrl || inputs.attachmentUrl === 'media_received') {\n    return { hasAttachment: false, fileName: null, fileUrl: null };\n  }\n\n  let url = inputs.attachmentUrl;\n  url = url.replace('http://localhost:3000', 'ENTER_YOUR_HUGGING_FACE_URL');\n  url = url.replace('http://127.0.0.1:3000', 'ENTER_YOUR_HUGGING_FACE_URL');\n  url = url.replace('http://localhost:7860', 'ENTER_YOUR_HUGGING_FACE_URL');\n\n  const response = await fetch(url, {\n    headers: { 'X-Api-Key': 'ENTER_WAHA_API_KEY' }\n  });\n\n  const buffer = await response.arrayBuffer();\n  const base64 = Buffer.from(buffer).toString('base64');\n  const contentType = response.headers.get('content-type')?.split(';')[0] || 'image/jpeg';\n  const ext = contentType.split('/')[1] || 'jpg';\n\n  return {\n    hasAttachment: true,\n    fileUrl: `data:${contentType};base64,${base64}`,\n    fileName: `attachment.${ext}`\n  };\n};",
