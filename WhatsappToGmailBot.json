                        "sourceCode": {
                          "code": "export const code = async (inputs) => {\n  // Don't send if reply is empty\n  if (!inputs.reply || inputs.reply.trim() === '') {\n    return { status: 'skipped' };\n  }\n\n  const tunnelUrl = 'ENTER_YOUR_HUGGING_FACE_URL';\n  const apiKey = 'ENTER_WAHA_API_KEY';\n  \n  const payload = {\n    chatId: inputs.sender,\n    text: inputs.reply,\n    session: 'default'\n  };\n\n  const response = await fetch(`${tunnelUrl}/api/sendText`, {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n      'X-Api-Key': apiKey\n    },\n    body: JSON.stringify(payload)\n  });\n\n  const result = await response.json();\n  return { status: response.status, result };\n};",
