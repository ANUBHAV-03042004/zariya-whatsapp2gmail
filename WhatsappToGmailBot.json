                    "sampleData": {},
                    "sourceCode": {
                      "code": "export const code = async (inputs) => {\n  let state = {};\n  try {\n    const raw = inputs.storedState;\n    if (typeof raw === 'string' && raw.trim() !== '') state = JSON.parse(raw);\n    else if (typeof raw === 'object' && raw !== null) state = raw;\n  } catch(e) { state = {}; }\n\n  const step = inputs.step;\n  const value = inputs.value;\n  const sender = inputs.sender;\n\n  let reply = '';\n  let newState = { ...state };\n  let readyToSend = false;\n\n  if (!state.stage && step !== 'hello') {\n    return {\n      reply: '',\n      newState: JSON.stringify({}),\n      readyToSend: false,\n      recipient: '',\n      body: '',\n      attachment: null,\n      sender,\n      ignoreMessage: true\n    };\n  }\n\n  if (!state.stage || step === 'hello' || step === 'confirm_no') {\n    newState = { stage: 'ask_recipient' };\n    reply = `👋 *Hello! I will help you send a formal email.*\\n\\nWho to send it to?\\n\\n📧 Reply: *To: email@example.com*`;\n\n  } else if (state.stage === 'ask_recipient' && step === 'recipient') {\n    newState.recipient = value;\n    newState.stage = 'ask_body';\n    reply = `✅ Sending to: *${value}*\\n\\nNow type your message (any language, informal is fine!):\\n\\n💬 Reply: *Body: your message here*`;\n\n  } else if (state.stage === 'ask_body' && step === 'body') {\n    newState.body = value;\n    newState.stage = 'ask_attachment';\n    reply = `✅ *Message saved!*\\n\\nDo you want to attach a file?\\n\\n📎 Send file now\\n⏭️ Or reply *SKIP*`;\n\n  } else if (state.stage === 'ask_attachment') {\n    if (step === 'skip_attachment') {\n      newState.attachment = null;\n    } else if (step === 'media') {\n      newState.attachment = value;\n    } else {\n      return {\n        reply: `📎 Please send a file/photo OR reply *SKIP*`,\n        newState: JSON.stringify(state),\n        readyToSend: false,\n        recipient: state.recipient || '',\n        body: state.body || '',\n        attachment: null,\n        sender,\n        ignoreMessage: false\n      };\n    }\n    newState.stage = 'confirm';\n    reply = `📋 *Review:*\\n\\n📧 *To:* ${newState.recipient}\\n💬 *Message:* ${newState.body}\\n📎 *Attachment:* ${newState.attachment ? 'Yes ✅' : 'None'}\\n\\nReply *YES* to send\\nReply *NO* to start over`;\n\n  } else if (state.stage === 'confirm' && step === 'confirm_yes') {\n    newState.stage = 'done';\n    readyToSend = true;\n    reply = `⏳ *Sending your email now...* Please wait!`;\n\n  } else {\n    return {\n      reply: '',\n      newState: JSON.stringify({}),\n      readyToSend: false,\n      recipient: '',\n      body: '',\n      attachment: null,\n      sender,\n      ignoreMessage: true\n    };\n  }\n\n  return {\n    reply,\n    newState: JSON.stringify(newState),\n    readyToSend,\n    recipient: newState.recipient || '',\n    body: newState.body || '',\n    attachment: newState.attachment || null,\n    sender,\n    ignoreMessage: false\n  };\n};",
